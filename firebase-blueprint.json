{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with channel information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "channelDescription": { "type": "string" },
        "isArtist": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Content": {
      "title": "Content",
      "description": "Video or Music Track",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "type": { "enum": ["video", "music"] },
        "visibility": { "enum": ["public", "private"] },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "metadata": { "type": "object" },
        "monetization": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "url", "type", "visibility", "authorId"]
    },
    "ApiKey": {
      "title": "API Key",
      "description": "Developer API credentials",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "userId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientSecret": { "type": "string" },
        "appType": { "enum": ["web", "backend", "native"] },
        "redirectUris": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Channel": {
      "title": "Channel",
      "description": "Content creator channel",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "enum": ["music", "gaming", "vlog", "tech", "general"] },
        "description": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "name", "type"]
    },
    "AuthToken": {
      "title": "Auth Token",
      "description": "Developer access and refresh tokens",
      "type": "object",
      "properties": {
        "accessToken": { "type": "string" },
        "refreshToken": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "clientId": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Store user profiles and channel settings"
    },
    "/channels/{channelId}": {
      "schema": "Channel",
      "description": "Store individual creator channels"
    },
    "/api_keys/{keyId}": {
      "schema": "ApiKey",
      "description": "Validator for external app requests"
    },
    "/auth_tokens/{tokenId}": {
      "schema": "AuthToken",
      "description": "Temporary and long-lived developer tokens"
    },
    "/content/{contentId}": {
      "schema": "Content",
      "description": "Store video and music track metadata"
    },
    "/content/{contentId}/analytics/{day}": {
      "schema": "object",
      "description": "Store usage analytics and monetization data"
    }
  }
}
